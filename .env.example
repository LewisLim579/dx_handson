# 프로젝트 루트에 복사:  copy .env.example .env  후 값 입력
# 이 파일은 저장소에 포함됩니다. 비밀 값은 .env 에만 넣고 커밋하지 마세요.

LOCAL_DATA_ROOT=local_data

# --- LLM 라우팅 ---
# auto(기본): 유튜브 요약은 GEMINI_API_KEY가 있으면 Gemini, X 판별은 Azure → OpenAI → Gemini 순
# gemini | azure | openai 로 고정할 수 있음
# LLM_PROVIDER=auto

# --- Google Gemini (유튜브 요약·선택 시 X 판별) ---
# API 키: https://aistudio.google.com/apikey 등
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Azure OpenAI (X 판별·유튜브: auto일 때 Gemini 없으면 여기) ---
AZURE_OPENAI_ENDPOINT=https://leiws-project-sandbox-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=lewis-gpt-5
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MAX_TOKENS=4096

# Azure 대신 OpenAI 직접 쓸 때만 (위 Azure 미설정·Gemini도 없을 때)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini

# --- 텔레그램 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- X (Twitter API v2) ---
TWITTER_BEARER_TOKEN=

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=

# --- AWS Lambda 로컬이 아닐 때 (로컬 CLI는 보통 불필요) ---
# APP_SECRET_ARN=
# S3_BUCKET=
